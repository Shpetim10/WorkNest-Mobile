{
  "expo": {
    "name": "WorkTrezz",
    "slug": "worktrezz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/png/app_icon.png",
    "scheme": [
      "worknest",
      "worknestmobile"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.worktrezz.app",
      "buildNumber": "1",
      "icon": "./assets/logos/png/app_icon.png"
    },
    "android": {
      "package": "com.worktrezz.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "worknest"
            },
            {
              "scheme": "worknestmobile"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAFC",
          "image": "./assets/images/splash-logo-contained.png",
          "imageWidth": 250,
          "resizeMode": "contain"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25743c20-3050-48c5-8c00-08a4371c17de"
      }
    },
    "owner": "shpetim10"
  }
}
